---

---

<footer class="brutal-footer">
  <div class="footer-content">
    <div class="copyright-info">
      <span class="copy-txt"
        >© 2026 FUGITIVOS. TODOS LOS DERECHOS RESERVADOS.</span
      >
      <div class="developer-credit">
        <span class="dev-label">DESARROLLADO POR</span>
        <a
          href="https://www.instagram.com/limasmirko/"
          target="_blank"
          class="dev-link"
        >
          <span class="icon-box">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </span>
          <span class="dev-name">MIRKO LIMAS</span>
          <span class="dev-tag">// DEVELOPER</span>
        </a>
      </div>
    </div>

    <div class="footer-nav">
      <a href="/teaser" class="footer-link">TEASER</a>
      <a href="/info" class="footer-link">INFO</a>
      <a href="/contacto" class="footer-link">CONTACTO</a>
    </div>
  </div>

  <div class="footer-bottom-bar"></div>
</footer>

<style>
  .brutal-footer {
    background: #000;
    color: var(--cream, #fff5e6);
    padding: clamp(3rem, 10vh, 6rem) clamp(1rem, 5vw, 6rem);
    border-top: 1px solid rgba(255, 245, 230, 0.05);
    font-family: "Oswald", sans-serif;
    position: relative;
    z-index: 10;
  }

  .footer-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .copyright-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .copy-txt {
    font-size: 0.7rem;
    letter-spacing: 4px;
    opacity: 0.4;
  }

  .developer-credit {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .dev-label {
    font-size: 0.55rem;
    letter-spacing: 4px;
    color: var(--cream);
    opacity: 0.3;
    font-weight: 400;
  }

  .dev-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 5px;
    transition: opacity 0.3s;
    opacity: 0.4;
    width: fit-content;
  }

  .dev-link:hover {
    opacity: 1;
  }

  .dev-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1;
    display: inline-block;
  }

  .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .icon-box svg {
    width: 100%;
    height: 100%;
    display: block;
    color: inherit;
  }

  .dev-tag {
    font-size: 0.6rem;
    letter-spacing: 2px;
    opacity: 0.5;
    font-weight: 300;
  }

  .footer-nav {
    display: flex;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .footer-link {
    font-size: 0.8rem;
    letter-spacing: 5px;
    color: var(--cream);
    text-decoration: none;
    opacity: 0.6;
    transition:
      opacity 0.3s,
      transform 0.3s;
    font-weight: 700;
  }

  .footer-link:hover {
    opacity: 1;
    color: #e60000;
    transform: translateY(-3px);
  }

  .footer-bottom-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 6px;
    background: #e60000;
    opacity: 0.8;
  }

  @media (max-width: 800px) {
    .footer-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 4rem;
    }

    .footer-nav {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
