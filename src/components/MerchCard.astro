---
import { Image } from "astro:assets";

interface Props {
  name: string;
  price: string;
  image: any;
  type: string;
  description: string;
  alternate?: boolean;
}

const { name, price, image, type, description, alternate = false } = Astro.props;
---

<article class={`merch-card-item ${alternate ? 'alternate' : ''} reveal`}>
  <div class="card-visual">
    <div class="img-container">
      <Image src={image} alt={name} class="shirt-photo" />
      <div class="noise-overlay"></div>
      <div class="glitch-bar"></div>
    </div>
    <span class="type-sticker">{type}</span>
  </div>

  <div class="card-details">
    <div class="title-price-wrap">
      <h2 class="distort-title" data-text={name}>{name}</h2>
      <span class="price-tag">{price}</span>
    </div>
    
    <p class="desc-txt">{description}</p>
    
    <div class="size-selector">
      <span class="size-label">SIZE_GUIDE</span>
      <div class="size-btns">
        <button>S</button>
        <button>M</button>
        <button class="active">L</button>
        <button>XL</button>
      </div>
    </div>

    <button class="order-btn">
      <span class="order-label">ADQUIRIR PIEZA</span>
      <span class="order-icon">→</span>
      <div class="btn-strobe"></div>
    </button>
  </div>
</article>

<style>
  .merch-card-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 8vw, 6rem);
    align-items: center;
    margin-bottom: 15vh;
  }

  .merch-card-item.alternate {
    direction: rtl;
  }
  .merch-card-item.alternate .card-details {
    direction: ltr;
  }

  @media (max-width: 900px) {
    .merch-card-item {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .merch-card-item.alternate { direction: ltr; }
  }

  /* ── VISUAL SIDE ── */
  .card-visual {
    position: relative;
    overflow: hidden;
  }

  .img-container {
    background: #111;
    aspect-ratio: 1/1;
    position: relative;
    border: 1px solid rgba(255, 245, 230, 0.1);
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .shirt-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.2);
    transition: all 0.5s ease;
  }

  .merch-card-item:hover .shirt-photo {
    filter: grayscale(0) contrast(1);
    transform: scale(1.03);
  }

  .noise-overlay {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    pointer-events: none;
    opacity: 0.2;
  }

  .type-sticker {
    position: absolute;
    top: 2rem;
    left: 2rem;
    background: #e60000;
    color: #fff;
    padding: 0.5rem 1.2rem;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 3px;
    z-index: 2;
  }

  /* ── DETAILS SIDE ── */
  .title-price-wrap {
    border-bottom: 2px solid var(--cream);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    position: relative;
  }

  .distort-title {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.85;
    text-transform: uppercase;
    margin-right: 4rem;
    position: relative;
  }

  .distort-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    color: #e60000;
    z-index: -1;
    opacity: 0;
    transition: all 0.2s;
  }

  .merch-card-item:hover .distort-title::after {
    opacity: 0.7;
    animation: textFlicker 0.2s infinite;
  }

  @keyframes textFlicker {
    0% { transform: translate(3px, -2px); }
    100% { transform: translate(-3px, 2px); }
  }

  .price-tag {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 1.8rem;
    font-weight: 300;
    opacity: 0.6;
  }

  .desc-txt {
    font-size: 1.1rem;
    line-height: 1.5;
    opacity: 0.5;
    max-width: 45ch;
    margin-bottom: 3rem;
  }

  /* ── SIZE GUID ── */
  .size-selector {
    margin-bottom: 4rem;
  }

  .size-label {
    font-size: 0.6rem;
    letter-spacing: 5px;
    opacity: 0.4;
    display: block;
    margin-bottom: 1.5rem;
  }

  .size-btns {
    display: flex;
    gap: 2rem;
  }

  .size-btns button {
    background: transparent;
    border: none;
    color: var(--cream);
    font-family: inherit;
    font-size: 1.5rem;
    font-weight: 700;
    cursor: pointer;
    padding: 0;
    opacity: 0.2;
    transition: all 0.3s;
  }

  .size-btns button.active, .size-btns button:hover {
    opacity: 1;
    color: #e60000;
  }

  /* ── ORDER BTN ── */
  .order-btn {
    width: 100%;
    background: var(--cream);
    color: #000;
    border: none;
    padding: 1.5rem 2rem;
    font-family: 'Oswald', sans-serif;
    font-weight: 900;
    font-size: 1.2rem;
    letter-spacing: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .order-btn:hover {
    background: #e60000;
    color: #fff;
  }

  .btn-strobe {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.2);
    opacity: 0;
    pointer-events: none;
  }

  .order-btn:hover .btn-strobe {
    animation: strobeFast 0.1s infinite;
  }

  @keyframes strobeFast {
    0% { opacity: 0; }
    50% { opacity: 1; }
    100% { opacity: 0; }
  }

  /* ── REVEAL ── */
  .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
      opacity: 1;
      transform: translateY(0);
  }

</style>
