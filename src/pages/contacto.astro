---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";

const members = [
  { name: "DANIEL RAMIREZ", role: "VOZ / CAOS", link: "https://www.instagram.com/angus_rush/" },
  { name: "LUCA RAMIREZ", role: "GUITARRA / DISTORSIÓN", link: "https://www.instagram.com/luca.ramirez.7758/" },
  { name: "VICTOR ALVA", role: "BAJO / PULSO", link: "https://www.instagram.com/victor.alvafalcon/" },
  { name: "WALTER RAMIREZ", role: "BATERÍA / IMPACTO", link: "https://www.instagram.com/choko22cm/" },
];
---

<Layout>
  <Header />

  <main id="ultra-contact">
    <div class="void-overlay"></div>
    <div class="feedback-lines"></div>

    <div class="contact-scroll-container">
      
      <div class="bg-title-wrap">
        <span class="bg-txt">FUGITIVOS</span>
        <span class="bg-txt outline">FUGITIVOS</span>
        <span class="bg-txt">FUGITIVOS</span>
      </div>

      <section class="mega-section">
        <!-- IZQUIERDA: TÍTULO ORIGINAL QUE TE GUSTA -->
        <div class="left-wing">
          <div class="torn-paper">
            <h1 class="main-title">CON<br/>TAC<br/>TO</h1>
            <div class="red-bar"></div>
          </div>
          
          <div class="manifesto-box">
              <span>ESTADO: ACTIVO</span>
              <p>LA FUGA NO SE DETIENE. ÚNETE AL INCIDENTE.</p>
          </div>
        </div>

        <!-- DERECHA: DETALLES ORIGINALES -->
        <div class="right-wing">
          <div class="brutal-details">
            <div class="d-row">
              <span class="d-num">01</span>
              <div class="d-info">
                <label>MANAGEMENT</label>
                <a href="mailto:CORREO@FUGITIVOS.ROCK">CORREO@FUGITIVOS.ROCK</a>
              </div>
            </div>
            
            <div class="d-row">
              <span class="d-num">02</span>
              <div class="d-info">
                <label>WHATSAPP LINE</label>
                <a href="#">+51 999 000 999</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════
           § THE CREW CARDS (ESTILO BRUTAL SOLO AQUÍ)
      ══════════════════════════════════════════ -->
      <section class="crew-section">
        <h2 class="section-label">// SIGUE EL RASTRO_</h2>
        
        <div class="crew-grid">
          {members.map((m, idx) => (
            <a href={m.link} class="brutal-card">
              <div class="card-inner">
                <div class="card-glitch"></div>
                <div class="card-content">
                    <span class="card-role">{m.role}</span>
                    <h3 class="card-name">{m.name}</h3>
                    <div class="card-footer">
                        <span class="card-action">FOLLOW_</span>
                        <span class="card-arrow">→</span>
                    </div>
                </div>
                <!-- Borde animado solo en hover -->
                <div class="border-t"></div>
                <div class="border-r"></div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <div class="industrial-tag">TYPE-001 // DISTORTION ACTIVE</div>
    </div>

    <Footer />
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Oswald:wght@400;700&display=swap');

  :root {
    --blood: #e60000;
    --black: #000000;
    --cream: #fff5e6;
  }

  body { background: var(--black); color: var(--cream); font-family: 'Oswald', sans-serif; overflow-x: hidden; }

  #ultra-contact { min-height: 100vh; padding-top: clamp(80px, 10vh, 140px); position: relative; }

  /* FX LAYERS ORIGINALES */
  .void-overlay { position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E"); pointer-events: none; z-index: 100; mix-blend-mode: overlay; }
  .feedback-lines { position: fixed; inset: 0; background: repeating-linear-gradient(0deg, transparent 0, transparent 2px, rgba(255, 255, 255, 0.02) 2px, rgba(255, 255, 255, 0.02) 3px); pointer-events: none; z-index: 50; }

  .contact-scroll-container { width: 100%; max-width: 1500px; margin: 0 auto; padding: 0 clamp(1rem, 5vw, 6rem); box-sizing: border-box; }

  /* BACKGROUND TEXT */
  .bg-title-wrap { position: fixed; top: 50%; left: 2%; transform: translateY(-50%) rotate(-90deg); opacity: 0.04; pointer-events: none; }
  .bg-txt { font-size: 20vw; font-weight: 900; line-height: 0.8; white-space: nowrap; }
  .bg-txt.outline { -webkit-text-stroke: 2px var(--cream); color: transparent; }

  /* MEGA SECTION (ORIGINAL) */
  .mega-section { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 5vw; margin-bottom: 8vh; }
  
  .torn-paper { 
    background: var(--cream); color: var(--black); padding: 1.5rem; width: fit-content; transform: rotate(-3deg);
    box-shadow: 10px 10px 0 var(--blood);
    clip-path: polygon(0% 0%, 100% 0%, 98% 45%, 100% 100%, 50% 98%, 0% 100%, 5% 50%);
  }
  .main-title { font-size: clamp(3.5rem, 10vw, 9rem); font-weight: 900; line-height: 0.75; letter-spacing: -4px; }
  .red-bar { width: 100%; height: 10px; background: var(--blood); margin-top: 1rem; }

  .manifesto-box { margin-top: 3rem; border-left: 3px solid var(--blood); padding-left: 2rem; }
  .manifesto-box span { font-family: 'Syncopate', sans-serif; font-size: 0.6rem; letter-spacing: 5px; color: var(--blood); }
  .manifesto-box p { font-size: clamp(1rem, 3vw, 2rem); font-weight: 700; text-transform: uppercase; max-width: 25ch; }

  .brutal-details { display: flex; flex-direction: column; gap: 4rem; }
  .d-row { display: flex; gap: 2rem; align-items: flex-start; }
  .d-num { color: var(--blood); font-weight: 800; font-size: 1.5rem; }
  .d-info label { font-size: 0.7rem; opacity: 0.4; letter-spacing: 5px; display: block; margin-bottom: 0.5rem; }
  .d-info a { font-size: clamp(1.2rem, 5vw, 4rem); font-weight: 900; color: var(--cream); text-decoration: none; word-break: break-all; line-height: 1; }
  .d-info a:hover { color: var(--blood); }

  /* ══════════════════════════════════════════
     CREW CARDS (ESTILO BRUTAL OPTIMIZADO)
  ══════════════════════════════════════════ */
  .crew-section { margin-top: 10vh; padding-bottom: 10vh; }
  .section-label { font-size: 1.2rem; letter-spacing: 12px; color: var(--blood); margin-bottom: 4rem; font-weight: 900; border-bottom: 1px solid rgba(230,0,0,0.2); padding-bottom: 1rem; display: inline-block; }
  
  .crew-grid { 
    display: grid; 
    grid-template-columns: repeat(4, 1fr); 
    gap: 20px; 
  }

  .brutal-card {
    background: #080808;
    text-decoration: none;
    color: var(--cream);
    position: relative;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    overflow: hidden;
  }

  .card-inner {
    padding: 2.5rem 2rem;
    height: 100%;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
  }

  .card-glitch {
    position: absolute; inset: 0;
    background: repeating-linear-gradient(rgba(230,0,0,0.1) 0, rgba(230,0,0,0.1) 1px, transparent 1px, transparent 3px);
    opacity: 0; transition: opacity 0.3s;
    z-index: 1;
  }

  .card-content { position: relative; z-index: 5; }
  .card-role { font-family: 'Syncopate', sans-serif; font-size: 0.55rem; color: var(--blood); letter-spacing: 3px; font-weight: 700; margin-bottom: 0.5rem; display: block; }
  .card-name { font-size: clamp(1.5rem, 2.5vw, 2.2rem); font-weight: 900; line-height: 1; margin-bottom: 1.5rem; }

  .card-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1rem; margin-top: 1rem; }
  .card-action { font-size: 0.7rem; font-weight: 700; opacity: 0.4; letter-spacing: 3px; }
  .card-arrow { color: var(--blood); transform: translateX(-10px); opacity: 0; transition: 0.3s; }

  /* Borders hover */
  .border-t { position: absolute; top: 0; left: 0; width: 0; height: 3px; background: var(--blood); transition: 0.4s; z-index: 10; }
  .border-r { position: absolute; top: 0; right: 0; width: 3px; height: 0; background: var(--blood); transition: 0.4s; z-index: 10; }

  /* Hover FX */
  .brutal-card:hover { transform: translateY(-10px); border-color: var(--blood); box-shadow: 0 30px 60px rgba(0,0,0,0.9); }
  .brutal-card:hover .card-glitch { opacity: 1; }
  .brutal-card:hover .card-arrow { transform: translateX(0); opacity: 1; }
  .brutal-card:hover .card-action { opacity: 1; color: var(--blood); }
  .brutal-card:hover .border-t { width: 100%; }
  .brutal-card:hover .border-r { height: 100%; }

  /* RESPONSIVE */
  @media (max-width: 1200px) {
    .crew-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .mega-section { grid-template-columns: 1fr; gap: 4rem; }
  }

  @media (max-width: 600px) {
    .crew-grid { grid-template-columns: 1fr; }
    .brutal-card .card-inner { min-height: 220px; }
    .main-title { font-size: 5rem; }
  }

  .industrial-tag { position: fixed; bottom: 2rem; right: 2rem; font-size: 0.5rem; opacity: 0.2; letter-spacing: 5px; }
</style>
