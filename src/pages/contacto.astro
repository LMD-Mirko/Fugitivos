---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Header />

  <main id="ultra-contact">
    <!-- ── THE "VOID" NOISE LAYER ── -->
    <div class="void-overlay"></div>
    <div class="feedback-lines"></div>

    <!-- ── ENTRY KICK FX (STROBE & SLAM) ── -->
    <div class="entry-strobe"></div>
    <div class="entry-flash-white"></div>

    <!-- ── ASYMMETRIC CONTENT ── -->
    <div class="contact-scroll-container">
      
      <!-- ── BACKGROUND TITLES (THE "GHOSTS") ── -->
      <div class="bg-title-wrap">
        <span class="bg-txt">FUGITIVOS</span>
        <span class="bg-txt outline">FUGITIVOS</span>
        <span class="bg-txt">FUGITIVOS</span>
      </div>

      <section class="mega-section">
        <div class="left-wing">
          <div class="torn-paper">
            <h1 class="main-title">CON<br/>TAC<br/>TO</h1>
            <div class="red-bar"></div>
          </div>
          
          <div class="manifesto-box">
              <span>ESTADO: ACTIVO</span>
              <p>NO SOMOS UNA EMPRESA. SOMOS UN INCIDENTE. SI TIENES LAS AGALLAS, ESCRIBE.</p>
          </div>
        </div>

        <div class="right-wing">
          <div class="brutal-details">
            <div class="d-row">
              <span class="d-num">01</span>
              <div class="d-info">
                <label>BOOKING & PRENSA</label>
                <a href="mailto:MANAGEMENT@FUGITIVOS.ROCK">MANAGEMENT@FUGITIVOS.ROCK</a>
              </div>
            </div>
            
            <div class="d-row">
              <span class="d-num">02</span>
              <div class="d-info">
                <label>LINEA DIRECTA</label>
                <a href="tel:+51999999999">+51 666 000 999</a>
              </div>
            </div>

            <div class="d-row">
              <span class="d-num">03</span>
              <div class="d-info">
                <label>COORDENADAS</label>
                <p>LIMA . SECTOR OSCURO . PERÚ</p>
              </div>
            </div>
          </div>

          <div class="form-container">
            <h2 class="form-header">ENVÍA EL MANIFIESTO</h2>
            <form id="chaos-form" onsubmit="event.preventDefault(); document.getElementById('success-glitch').style.display='flex'">
              <div class="input-block">
                <input type="text" placeholder="¿QUIÉN ERES?" required />
                <div class="scan-line"></div>
              </div>
              <div class="input-block">
                <input type="email" placeholder="CORREO@ELECTRÓNICO" required />
                <div class="scan-line"></div>
              </div>
              <div class="input-block">
                <textarea placeholder="MENSAJE DE ALTO VOLTAJE..." rows="3" required></textarea>
                <div class="scan-line"></div>
              </div>
              
              <button type="submit" class="brutal-submit">
                <span class="cross"></span>
                DISPARAR
                <span class="cross"></span>
              </button>
            </form>
          </div>
        </div>
      </section>

      <!-- ── DECORATIVE ARTIFACTS ── -->
      <div class="industrial-tag">TYPE-001 // DISTORTION ACTIVE</div>
      <div class="warning-tape">WARNING: HIGH FREQUENCY // WARNING: HIGH FREQUENCY</div>
    </div>

    <!-- ── SUCCESS OVERLAY (GLITCH) ── -->
    <div id="success-glitch" style="display:none;">
        <div class="glitch-box">
            <h1>MENSAJE RECIBIDO</h1>
            <p>EL ÉTER YA LO TIENE.</p>
            <button onclick="location.reload()">VOLVER</button>
        </div>
    </div>

    <Footer />
  </main>
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&display=swap');

  :root {
    --cream: #fff5e6;
    --black: #000000;
    --blood: #e60000;
    --dirty-gray: #1a1a1a;
  }

  body {
    background: var(--black);
    overflow-x: hidden;
    animation: entryShake 0.4s 0.2s ease-in-out both;
  }

  #ultra-contact {
    min-height: 100vh;
    color: var(--cream);
    font-family: 'Oswald', sans-serif;
    position: relative;
    padding-top: clamp(100px, 15vh, 180px);
    background: radial-gradient(circle at 30% 30%, #0a0a0a 0%, #000 100%);
    overflow: hidden;
  }

  /* ── FX LAYERS ── */
  .void-overlay {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 100;
    mix-blend-mode: overlay;
  }

  .feedback-lines {
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 2px,
      rgba(255, 255, 255, 0.02) 2px,
      rgba(255, 255, 255, 0.02) 3px
    );
    pointer-events: none;
    z-index: 50;
    animation: flickerVanish 0.1s infinite alternate;
  }

  @keyframes flickerVanish {
    0% { opacity: 0.3; }
    100% { opacity: 0.8; }
  }

  /* ── BACKGROUND TYPO ── */
  .bg-title-wrap {
    position: fixed;
    top: 50%;
    left: 2%;
    transform: translateY(-50%) rotate(-90deg);
    display: flex;
    flex-direction: column;
    z-index: 0;
    pointer-events: none;
    opacity: 0.04;
    animation: revealBg 2s 1s ease-out both;
  }

  @media (max-width: 800px) {
    .bg-title-wrap { display: none; }
  }

  .bg-txt {
    font-size: 25vw;
    font-weight: 900;
    line-height: 0.8;
    white-space: nowrap;
  }

  .bg-txt.outline {
    -webkit-text-stroke: 2px var(--cream);
    color: transparent;
  }

  /* ── MAIN CONTENT ── */
  .contact-scroll-container {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 5vw, 4rem);
    box-sizing: border-box;
  }

  /* ── ENTRY BRUTAL REVEAL ── */
  .entry-strobe {
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 9999;
    pointer-events: none;
    animation: brutalStrobe 0.4s steps(2) forwards;
  }
  
  @keyframes brutalStrobe {
    0% { opacity: 1; }
    20% { opacity: 0; }
    40% { opacity: 0.8; }
    60% { opacity: 0; }
    80% { opacity: 0.4; }
    100% { opacity: 0; visibility: hidden; }
  }

  .entry-flash-white {
    position: fixed;
    inset: 0;
    background: var(--cream);
    z-index: 9998;
    pointer-events: none;
    animation: flashOut 1s 0.3s cubic-bezier(0.8, 0, 0.2, 1) forwards;
    opacity: 0;
  }

  @keyframes flashOut {
    0% { opacity: 1; transform: scaleY(1); }
    100% { opacity: 0; transform: scaleY(0); transform-origin: top; }
  }

  @keyframes revealBg {
    0% { opacity: 0; transform: translateY(-50%) rotate(-90deg) scale(0.8); }
    100% { opacity: 0.04; transform: translateY(-50%) rotate(-90deg) scale(1); }
  }

  @keyframes entryShake {
    0%, 100% { transform: translate(0, 0); }
    20% { transform: translate(-3px, 3px); }
    40% { transform: translate(3px, -3px); }
    60% { transform: translate(-3px, -3px); }
    80% { transform: translate(3px, 3px); }
  }

  .mega-section {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 5vw;
    align-items: start;
    perspective: 1000px;
  }

  @media (max-width: 1000px) {
    .mega-section { grid-template-columns: 1fr; }
  }

  /* ── LEFT WING ── */
  .left-wing {
    animation: slamLeft 0.6s 0.4s cubic-bezier(0.19, 1, 0.22, 1) both;
  }
  
  @keyframes slamLeft {
    0% { transform: translateX(-100px) rotate(-10deg); opacity: 0; filter: blur(20px); }
    100% { transform: translateX(0) rotate(0); opacity: 1; filter: blur(0); }
  }

  .torn-paper {
    position: relative;
    padding: 2rem;
    background: var(--cream);
    color: var(--black);
    width: fit-content;
    transform: rotate(-3deg);
    box-shadow: 20px 20px 0 var(--blood);
    clip-path: polygon(0% 0%, 100% 0%, 95% 45%, 100% 100%, 50% 95%, 0% 100%, 5% 50%);
  }

  .main-title {
    font-size: clamp(5rem, 15vw, 12rem);
    font-weight: 900;
    line-height: 0.75;
    letter-spacing: -5px;
  }

  .red-bar {
    width: 100%;
    height: 15px;
    background: var(--blood);
    margin-top: 1rem;
  }

  .manifesto-box {
    margin-top: 6rem;
    border-left: 4px solid var(--blood);
    padding-left: 2rem;
  }

  .manifesto-box span {
    font-family: 'Syncopate', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 5px;
    color: var(--blood);
    display: block;
    margin-bottom: 1rem;
  }

  .manifesto-box p {
    font-size: clamp(1.1rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.1;
    max-width: 25ch;
    text-transform: uppercase;
  }

  /* ── RIGHT WING ── */
  .right-wing {
    animation: slamRight 0.6s 0.6s cubic-bezier(0.19, 1, 0.22, 1) both;
  }

  @keyframes slamRight {
    0% { transform: translateX(100px) rotate(10deg); opacity: 0; filter: blur(20px); }
    100% { transform: translateX(0) rotate(0); opacity: 1; filter: blur(0); }
  }

  .brutal-details {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-bottom: 8rem;
  }

  .d-row {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    transition: transform 0.3s;
  }

  .d-row:hover { transform: translateX(20px); }

  .d-num {
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--blood);
    opacity: 0.8;
  }

  .d-info label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 6px;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }

  .d-info a, .d-info p {
    font-size: clamp(1.2rem, 6vw, 3.8rem);
    font-weight: 900;
    text-decoration: none;
    color: var(--cream);
    line-height: 0.95;
    word-break: break-all;
    display: block;
  }

  .d-info a:hover {
    color: var(--blood);
    text-shadow: 5px 5px 0 rgba(230, 0, 0, 0.3);
  }

  /* ── CHAOS FORM ── */
  .form-container {
    background: #080808;
    padding: clamp(1.5rem, 5vw, 4rem);
    border: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    width: 100%;
    box-sizing: border-box;
  }

  .form-container::before {
    content: '';
    position: absolute;
    top: -10px; left: -10px;
    width: 20px; height: 20px;
    border-top: 2px solid var(--blood);
    border-left: 2px solid var(--blood);
  }

  .form-header {
    font-size: 1.2rem;
    letter-spacing: 8px;
    margin-bottom: 4rem;
    text-transform: uppercase;
    color: var(--blood);
  }

  .input-block {
    margin-bottom: 3rem;
    position: relative;
  }

  .input-block input, .input-block textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1rem 0;
    color: var(--cream);
    font-family: inherit;
    font-size: 1.5rem;
    text-transform: uppercase;
    outline: none;
  }

  .scan-line {
    position: absolute;
    bottom: 0; left: 0;
    width: 0%;
    height: 2px;
    background: var(--blood);
    transition: width 0.5s cubic-bezier(0.77, 0, 0.18, 1);
  }

  .input-block input:focus ~ .scan-line,
  .input-block textarea:focus ~ .scan-line {
    width: 100%;
  }

  .brutal-submit {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: var(--blood);
    color: var(--black);
    border: none;
    padding: 1.5rem 4rem;
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    transition: all 0.2s;
  }

  .brutal-submit:hover {
    background: var(--cream);
    transform: scale(0.98);
    box-shadow: 0 0 30px rgba(255, 245, 230, 0.3);
  }

  .cross {
    width: 15px;
    height: 15px;
    position: relative;
  }
  .cross::before, .cross::after {
    content: '';
    position: absolute;
    background: currentColor;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }
  .cross::before { width: 100%; height: 2px; }
  .cross::after { width: 2px; height: 100%; }

  /* ── INDUSTRIAL DECO ── */
  .industrial-tag {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    font-family: 'Syncopate', sans-serif;
    font-size: 0.6rem;
    opacity: 0.3;
    pointer-events: none;
  }

  .warning-tape {
    position: absolute;
    bottom: -10rem;
    left: -50vw;
    width: 200vw;
    background: #ffcc00;
    color: #000;
    padding: 1rem;
    font-weight: 900;
    transform: rotate(5deg);
    white-space: nowrap;
    animation: marquee 20s linear infinite;
  }

  @keyframes marquee {
    0% { transform: translateX(0) rotate(5deg); }
    100% { transform: translateX(-50%) rotate(5deg); }
  }

  /* ── SUCCESS OVERLAY ── */
  #success-glitch {
    position: fixed;
    inset: 0;
    background: var(--black);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .glitch-box h1 { font-size: 5rem; color: var(--blood); }
  .glitch-box p { font-size: 1.5rem; letter-spacing: 5px; margin-bottom: 2rem; }
  .glitch-box button {
      padding: 1rem 3rem;
      background: var(--cream);
      border: none;
      font-weight: 900;
      cursor: pointer;
  }

  /* ── ADAPTABILITY ── */
  @media (max-width: 1000px) {
    .brutal-details { gap: 2.5rem; margin-bottom: 5rem; }
    .manifesto-box { margin-top: 3rem; }
    .torn-paper { width: 100%; max-width: 400px; box-shadow: 10px 10px 0 var(--blood); }
  }

  @media (max-width: 600px) {
    #ultra-contact { padding-top: 160px; }
    .main-title { font-size: clamp(4rem, 20vw, 7rem); }
    .form-container { padding: 1.5rem; }
    .brutal-submit { padding: 1.2rem 1rem; font-size: 1.1rem; }
    .input-block input, .input-block textarea { font-size: 1.2rem; }
    .warning-tape { display: none; }
  }

  @media (max-width: 360px) {
      .main-title { font-size: 3.5rem; }
      .manifesto-box { padding-left: 1rem; }
  }
</style>
