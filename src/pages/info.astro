---
import { Image } from "astro:assets";
import coverImage from "../assets/imagen portada (1).jpeg";
import logo from "../assets/logo.png";
import img1 from "../assets/imagenes/530656272_18083226982870711_8446053491263136157_n.jpg";
import img2 from "../assets/imagenes/530695379_18083227009870711_6105568548409570651_n.jpg";
import img3 from "../assets/imagenes/532190492_18083227072870711_4109783596938428425_n.jpg";
import img4 from "../assets/imagenes/DSC_1536.JPG.jpeg";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fugitivos — La Banda</title>
    <meta
      name="description"
      content="Fugitivos — Banda de Rock. Conoce al grupo, escucha su música y síguelos en redes."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&family=Permanent+Marker&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ══════════════════════════════════════════
       TOKENS
    ══════════════════════════════════════════ */
      :root {
        --cream: #fff5e6;
        --black: #020202;
        --gray: #1a1a1a;
        --muted: rgba(255, 245, 230, 0.35);
      }

      /* ══════════════════════════════════════════
       RESET & BASE
    ══════════════════════════════════════════ */
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: var(--cream) var(--black);
      }
      ::-webkit-scrollbar {
        width: 3px;
      }
      ::-webkit-scrollbar-track {
        background: var(--black);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--cream);
      }

      body {
        background: var(--black);
        color: var(--cream);
        font-family: "Oswald", sans-serif;
        overflow-x: hidden;
        cursor: none;
      }

      /* ── NOISE GRAIN ── */
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.1'/%3E%3C/svg%3E");
        opacity: 0.18;
        mix-blend-mode: overlay;
        pointer-events: none;
        z-index: 9000;
      }

      /* ── CUSTOM CURSOR ── */
      #cur {
        position: fixed;
        width: 16px;
        height: 16px;
        border: 1px solid var(--cream);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        transition:
          width 0.2s,
          height 0.2s,
          background 0.2s;
      }
      #cur::before,
      #cur::after {
        content: "";
        position: absolute;
        background: var(--cream);
      }
      #cur::before {
        width: 1px;
        height: 8px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
      #cur::after {
        width: 8px;
        height: 1px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
      body:hover #cur {
      }

      /* ── SCROLL REVEAL ── */
      .reveal {
        opacity: 0;
        transform: translateY(4vh);
        transition:
          opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-left {
        opacity: 0;
        transform: translateX(-6vw);
        transition:
          opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .reveal-left.visible {
        opacity: 1;
        transform: translateX(0);
      }

      /* ══════════════════════════════════════════
       § 1 — HERO
    ══════════════════════════════════════════ */
      #hero {
        position: relative;
        min-height: 100dvh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr;
        overflow: hidden;
      }
      @media (max-width: 768px) {
        #hero {
          display: flex;
          flex-direction: column;
          min-height: 100dvh;
        }
        .hero-polaroids {
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 2vh 0 6vh;
          flex: 0 0 auto;
        }
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            to top,
            var(--black) 0%,
            rgba(0, 0, 0, 0.5) 60%,
            rgba(0, 0, 0, 0.2) 100%
          ),
          /* band photo placeholder — replace with real image */
          radial-gradient(ellipse at 60% 40%, #2a2a2a 0%, #000 100%);
        background-size: cover;
        background-position: center;
      }

      /* Horizontal scan lines decoration */
      .hero-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0px,
          transparent 3px,
          rgba(0, 0, 0, 0.08) 3px,
          rgba(0, 0, 0, 0.08) 4px
        );
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        padding: clamp(6rem, 10vh, 9rem) clamp(1.5rem, 5vw, 5rem)
          clamp(2rem, 3vh, 3rem);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        grid-column: 1;
        flex: 1;
      }
      @media (max-width: 768px) {
        .hero-content {
          padding: 7rem 1.5rem 1.5rem;
          flex: 1;
          min-height: 0;
        }
      }

      /* ── POLAROID STACK (right column) ── */
      .hero-polaroids {
        grid-column: 2;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
      }

      .polaroid-stack {
        position: relative;
        width: clamp(150px, 28vw, 320px);
        height: clamp(185px, 34vw, 390px);
        cursor: pointer;
      }
      @media (max-width: 768px) {
        .polaroid-stack {
          width: 160px;
          height: 195px;
        }
      }

      /* ── FAN OUT state ── */
      .polaroid-stack.fanned .pol:nth-child(1) {
        transform: rotate(-28deg) translate(-110%, 10%) scale(0.97);
        z-index: 1;
      }
      .polaroid-stack.fanned .pol:nth-child(2) {
        transform: rotate(-10deg) translate(-40%, 0%) scale(1);
        z-index: 2;
      }
      .polaroid-stack.fanned .pol:nth-child(3) {
        transform: rotate(8deg) translate(35%, 5%) scale(1);
        z-index: 3;
      }
      .polaroid-stack.fanned .pol:nth-child(4) {
        transform: rotate(26deg) translate(105%, 10%) scale(0.97);
        z-index: 4;
      }

      /* Active card floats up when fanned */
      .polaroid-stack.fanned .pol.pol-active {
        z-index: 10 !important;
        transform: rotate(0deg) translateY(-18px) scale(1.08) !important;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.9);
      }

      /* Hint: small label to click */
      .polaroid-stack::after {
        content: "CLIC PARA VER";
        position: absolute;
        bottom: -2.5rem;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.6rem;
        letter-spacing: 4px;
        color: rgba(255, 245, 230, 0.3);
        white-space: nowrap;
        transition: opacity 0.3s;
      }
      .polaroid-stack.fanned::after {
        opacity: 0;
      }

      .pol {
        position: absolute;
        inset: 0;
        background: var(--cream);
        padding: 10px 10px 36px 10px;
        box-shadow:
          0 8px 40px rgba(0, 0, 0, 0.8),
          0 2px 8px rgba(0, 0, 0, 0.5);
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform;
      }

      .pol:nth-child(1) {
        transform: rotate(-8deg) translateY(-4px);
        z-index: 1;
      }
      .pol:nth-child(2) {
        transform: rotate(3deg) translateY(2px);
        z-index: 2;
      }
      .pol:nth-child(3) {
        transform: rotate(-2deg) translateY(-2px);
        z-index: 3;
      }
      .pol:nth-child(4) {
        transform: rotate(6deg) translateY(4px);
        z-index: 4;
      }

      .pol-photo {
        width: 100%;
        height: 80%;
        object-fit: cover;
        display: block;
      }

      /* CSS-only photo placeholders */
      .pol-photo.ph1 {
        background: linear-gradient(135deg, #1a1a1a 0%, #3a3a3a 40%, #111 100%);
      }
      .pol-photo.ph2 {
        background: linear-gradient(160deg, #2a2a2a 0%, #111 50%, #444 100%);
      }
      .pol-photo.ph3 {
        background: linear-gradient(110deg, #111 0%, #2f2f2f 60%, #1a1a1a 100%);
      }
      .pol-photo.ph4 {
        background: linear-gradient(145deg, #333 0%, #111 45%, #222 100%);
      }

      /* grain on each placeholder */
      .pol-photo::after {
        content: "";
        position: absolute;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.15'/%3E%3C/svg%3E");
        opacity: 0.35;
        mix-blend-mode: overlay;
        pointer-events: none;
      }

      .pol-caption {
        font-family: "Permanent Marker", cursive;
        font-size: clamp(0.7rem, 1.2vw, 1rem);
        color: #1a1a1a;
        text-align: center;
        padding-top: 8px;
        line-height: 1.2;
      }

      .hero-eyebrow {
        font-size: clamp(0.65rem, 1.2vh, 1rem);
        letter-spacing: 8px;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 2vh;
      }

      .hero-title {
        font-size: clamp(4rem, 14vw, 18rem);
        font-weight: 900;
        line-height: 0.88;
        letter-spacing: -3px;
        text-transform: uppercase;
        color: var(--cream);
        filter: grayscale(1) brightness(1.6) sepia(0.3);
      }
      @media (max-width: 768px) {
        .hero-title {
          font-size: clamp(4.5rem, 22vw, 8rem);
          letter-spacing: -2px;
        }
      }

      .hero-title span {
        display: block;
      }

      .hero-sub {
        margin-top: 4vh;
        font-size: clamp(0.9rem, 1.8vh, 1.4rem);
        letter-spacing: 4px;
        color: var(--muted);
        text-transform: uppercase;
        max-width: 40ch;
      }

      .hero-scroll-hint {
        margin-top: 2.5vh;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.7rem;
        letter-spacing: 5px;
        color: var(--muted);
        text-transform: uppercase;
      }
      .hero-scroll-hint::before {
        content: "";
        display: block;
        width: 40px;
        height: 1px;
        background: var(--muted);
      }

      /* logo top-left */
      .hero-logo {
        position: absolute;
        top: clamp(1.5rem, 4vh, 3rem);
        left: clamp(1.5rem, 4vw, 4rem);
        z-index: 3;
      }
      .hero-logo img {
        height: clamp(90px, 15vh, 180px);
        width: auto;
        filter: grayscale(1) brightness(1.6) sepia(0.3);
      }

      /* back link */
      .hero-back {
        position: absolute;
        top: clamp(1.5rem, 4vh, 3rem);
        right: clamp(1.5rem, 4vw, 4rem);
        z-index: 3;
        font-size: 0.75rem;
        letter-spacing: 4px;
        color: var(--muted);
        text-decoration: none;
        text-transform: uppercase;
        border-bottom: 1px solid transparent;
        transition:
          color 0.3s,
          border-color 0.3s;
      }
      .hero-back:hover {
        color: var(--cream);
        border-color: var(--cream);
      }

      /* ══════════════════════════════════════════
       § 2 — MANIFESTO
    ══════════════════════════════════════════ */
      #manifesto {
        padding: clamp(3rem, 8vh, 10rem) clamp(1.5rem, 6vw, 8rem);
        border-top: 1px solid rgba(255, 245, 230, 0.06);
      }
      @media (max-width: 768px) {
        #manifesto {
          padding: 3rem 1.5rem;
        }
      }

      .manifesto-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: clamp(2rem, 6vw, 8rem);
        align-items: start;
      }

      @media (max-width: 640px) {
        .manifesto-grid {
          grid-template-columns: 1fr;
        }
      }

      .manifesto-label {
        font-size: 0.7rem;
        letter-spacing: 6px;
        color: var(--muted);
        text-transform: uppercase;
        padding-top: 0.4rem;
      }

      .manifesto-text {
        font-size: clamp(1.6rem, 3.5vw, 3.2rem);
        font-weight: 300;
        line-height: 1.25;
        letter-spacing: -1px;
        color: var(--cream);
      }

      .manifesto-text strong {
        font-weight: 700;
        font-style: italic;
      }

      /* ══════════════════════════════════════════
       § 3 — SOCIAL LINKS (EDITORIAL STRIPS)
    ══════════════════════════════════════════ */
      #links {
        border-top: 1px solid rgba(255, 245, 230, 0.06);
      }

      .links-header {
        padding: clamp(3rem, 6vh, 5rem) clamp(1.5rem, 6vw, 8rem) 0;
        font-size: 0.7rem;
        letter-spacing: 6px;
        color: var(--muted);
        text-transform: uppercase;
      }

      .social-strip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: clamp(1.4rem, 3.5vh, 2.2rem) clamp(1.2rem, 6vw, 8rem);
        min-height: 64px; /* accessible touch target */
        border-bottom: 1px solid rgba(255, 245, 230, 0.06);
        text-decoration: none;
        color: var(--cream);
        position: relative;
        overflow: hidden;
        transition: color 0.35s;
        gap: 2rem;
        -webkit-tap-highlight-color: transparent;
      }

      /* fill from left on hover */
      .social-strip::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--cream);
        transform: translateX(-101%);
        transition: transform 0.45s cubic-bezier(0.77, 0, 0.18, 1);
        z-index: 0;
      }
      .social-strip:hover::before {
        transform: translateX(0);
      }
      .social-strip:hover {
        color: var(--black);
      }

      .strip-left {
        display: flex;
        align-items: center;
        gap: clamp(1rem, 3vw, 3rem);
        position: relative;
        z-index: 1;
      }

      .strip-num {
        font-size: clamp(0.65rem, 1vh, 0.85rem);
        letter-spacing: 4px;
        opacity: 0.4;
        min-width: 2.5rem;
      }

      .strip-icon {
        width: clamp(28px, 4vh, 42px);
        height: clamp(28px, 4vh, 42px);
        opacity: 0.7;
        flex-shrink: 0;
      }

      .strip-name {
        font-size: clamp(1.3rem, 5vw, 3.5rem);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -1px;
        line-height: 1;
      }

      .strip-handle {
        font-size: clamp(0.6rem, 1.1vh, 0.85rem);
        letter-spacing: 3px;
        opacity: 0.4;
        font-weight: 300;
      }
      @media (max-width: 480px) {
        .strip-handle {
          display: none;
        }
      }

      .strip-arrow {
        position: relative;
        z-index: 1;
        font-size: clamp(1.2rem, 2.5vw, 2.5rem);
        opacity: 0.3;
        transition:
          opacity 0.3s,
          transform 0.3s;
      }
      .social-strip:hover .strip-arrow {
        opacity: 1;
        transform: translateX(6px);
      }

      /* ══════════════════════════════════════════
       SINGLES TICKER
    ══════════════════════════════════════════ */
      .singles-ticker {
        overflow: hidden;
        border-top: 1px solid rgba(255, 245, 230, 0.06);
        border-bottom: 1px solid rgba(255, 245, 230, 0.06);
        padding: 1.6vh 0;
        background: transparent;
        position: relative;
      }
      .singles-ticker::before,
      .singles-ticker::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 8vw;
        z-index: 1;
        pointer-events: none;
      }
      .singles-ticker::before {
        left: 0;
        background: linear-gradient(to right, var(--black), transparent);
      }
      .singles-ticker::after {
        right: 0;
        background: linear-gradient(to left, var(--black), transparent);
      }

      .ticker-track {
        display: flex;
        align-items: center;
        gap: clamp(1.5rem, 4vw, 4rem);
        white-space: nowrap;
        animation: tickerScroll 40s linear infinite;
        width: max-content;
      }
      .ticker-track span {
        font-size: clamp(0.75rem, 1.4vw, 1.1rem);
        font-weight: 700;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: var(--cream);
        opacity: 0.55;
      }
      .ticker-dot {
        font-size: 0.6rem !important;
        opacity: 0.3 !important;
        letter-spacing: 0 !important;
      }
      @keyframes tickerScroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      /* Pause on hover (desktop) */
      .singles-ticker:hover .ticker-track {
        animation-play-state: paused;
      }

      /* ══════════════════════════════════════════
       § 4 — SINGLE SHOWCASE
    ══════════════════════════════════════════ */
      #single {
        padding: clamp(3rem, 8vh, 10rem) clamp(1.5rem, 6vw, 8rem);
        border-top: 1px solid rgba(255, 245, 230, 0.06);
      }
      @media (max-width: 768px) {
        #single {
          padding: 3rem 1.5rem;
        }
      }

      .single-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(3rem, 6vw, 8rem);
        align-items: center;
      }
      @media (max-width: 700px) {
        .single-grid {
          grid-template-columns: 1fr;
        }
      }

      .single-cover {
        aspect-ratio: 1;
        background: var(--gray);
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 245, 230, 0.08);
      }
      .single-cover::before {
        content: "PORTADA\ASÍ";
        white-space: pre;
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        letter-spacing: 6px;
        color: rgba(255, 245, 230, 0.15);
        text-align: center;
      }
      /* corner marks */
      .single-cover::after {
        content: "";
        position: absolute;
        inset: 12px;
        border: 1px solid rgba(255, 245, 230, 0.08);
        pointer-events: none;
      }

      .single-info {
        display: flex;
        flex-direction: column;
        gap: 3vh;
      }

      .single-eyebrow {
        font-size: 0.7rem;
        letter-spacing: 6px;
        color: var(--muted);
        text-transform: uppercase;
      }

      .single-title {
        font-size: clamp(2.5rem, 6vw, 6rem);
        font-weight: 900;
        line-height: 0.9;
        letter-spacing: -2px;
        text-transform: uppercase;
        color: var(--cream);
      }

      .single-date {
        font-size: clamp(0.75rem, 1.4vh, 1rem);
        letter-spacing: 6px;
        color: var(--muted);
        text-transform: uppercase;
        border-left: 2px solid var(--cream);
        padding-left: 1rem;
      }

      .single-ctas {
        display: flex;
        flex-direction: column;
        gap: 1.2vh;
        margin-top: 1vh;
      }

      .single-cta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.6vh 2.4vh;
        border: 1px solid rgba(255, 245, 230, 0.15);
        text-decoration: none;
        color: var(--cream);
        font-size: clamp(0.8rem, 1.4vh, 1.1rem);
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        transition:
          background 0.35s,
          color 0.35s;
        position: relative;
        overflow: hidden;
      }
      .single-cta::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--cream);
        transform: translateX(-101%);
        transition: transform 0.4s cubic-bezier(0.77, 0, 0.18, 1);
      }
      .single-cta:hover::before {
        transform: translateX(0);
      }
      .single-cta:hover {
        color: var(--black);
      }
      .single-cta span,
      .single-cta svg {
        position: relative;
        z-index: 1;
      }

      /* ══════════════════════════════════════════
       § 5 — FOOTER
    ══════════════════════════════════════════ */
      footer {
        border-top: 1px solid rgba(255, 245, 230, 0.06);
        padding: clamp(2rem, 5vh, 4rem) clamp(1.5rem, 6vw, 8rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 2rem;
      }

      .footer-copy {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--muted);
        text-transform: uppercase;
      }

      .footer-back {
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--muted);
        text-transform: uppercase;
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition:
          color 0.3s,
          border-color 0.3s;
      }
      .footer-back:hover {
        color: var(--cream);
