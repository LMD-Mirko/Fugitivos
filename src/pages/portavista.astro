---
import { Image } from "astro:assets";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";

// Assets
import img1 from "../assets/imagenes/530656272_18083226982870711_8446053491263136157_n.webp";
import img2 from "../assets/imagenes/530695379_18083227009870711_6105568548409570651_n.webp";
import img3 from "../assets/imagenes/532190492_18083227072870711_4109783596938428425_n.webp";
import img4 from "../assets/imagenes/imagen.webp";

const bandPhotos = [
  { img: img1, label: "01 // IMPACTO", details: "LIMA 2026 . VIVO" },
  { img: img2, label: "02 // RUIDO", details: "SESIONES DE SANGRE" },
  { img: img3, label: "03 // FUGA", details: "HASTA MIS MIEDOS" },
  { img: img4, label: "04 // CAOS", details: "IDENTIDAD SISTÉMICA" },
];
---

<Layout>
  <Header />

  <main id="ultra-portavista">
    <div class="noise-bg"></div>
    <div class="vignette"></div>
    <div class="red-flash-overlay" id="flash"></div>

    <!-- ── HUD CINEMÁTICO REFINADO ── -->
    <div class="hud">
        <div class="hud-top">
            <span>SISTEMA_PORTAVISTA // VISUAL_LOG_001</span>
            <div class="hud-line"></div>
            <div class="hud-mode">MODO_Z_STACK: MANUAL/AUTO</div>
        </div>
        
        <div class="hud-credits">
            <span class="hud-label">AUTHOR</span>
            <a href="https://www.instagram.com/limasmirko/" target="_blank" class="hud-dev">MIRKO LIMAS</a>
        </div>

        <div class="hud-bottom">
            <div class="status-box">
                <span class="pulse"></span>
                <span>DATA_STREAM: CRITICAL</span>
            </div>
            
            <!-- NAVEGACIÓN POR MINIATURAS (LO NUEVO) -->
            <div class="thumb-nav" id="thumb-nav">
                {bandPhotos.map((p, i) => (
                    <button class="thumb-btn" data-index={i} aria-label={`Ver foto ${i + 1}`}>
                        <div class="thumb-inner">
                            <Image src={p.img} alt="Thumb" class="thumb-img" />
                            <div class="btn-overlay"></div>
                        </div>
                        <span class="btn-idx">{i + 1}</span>
                    </button>
                ))}
            </div>

            <span class="legal">© 2026 FUGITIVOS</span>
        </div>
    </div>

    <!-- ══════════════════════════════════════════
       § THE Z-SLAM STACK (CON PROFUNDIDAD MEJORADA)
    ══════════════════════════════════════════ -->
    <section class="master-stack-container">
      <div class="stack-wrapper" id="master-stack">
        {bandPhotos.map((photo, index) => (
          <div class="stack-item" style={`--idx: ${index}`}>
            <div class="item-frame" data-label={photo.label} data-details={photo.details}>
                <Image src={photo.img} alt="Fugitivos" class="stack-img" />
                <div class="distort-layer"></div>
                <!-- Mini label de navegación rápida -->
                <div class="peek-label">{photo.label}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="slam-data">
          <h2 id="active-label">01 // IMPACTO</h2>
          <p id="active-details">LIMA 2026 . VIVO</p>
      </div>
    </section>

    <!-- ── CINEMA MODE ── -->
    <div id="cinema-mode" class="cinema-overlay">
        <div class="strobe-layer"></div>
        <div class="cinema-content">
            <button id="close-cinema">REGRESAR_X</button>
            <div class="cinema-img-box">
                <img src="" id="cinema-img" alt="Focus View" />
            </div>
            <div class="cinema-meta">
                <h3 id="cinema-label">LABEL</h3>
                <div class="divider"></div>
                <p id="cinema-details">DETAILS</p>
            </div>
        </div>
    </div>
  </main>
</Layout>

<style is:global>
  :root {
    --blood: #e60000;
    --black: #020202;
    --cream: #fff5e6;
  }

  body { background: var(--black); overflow: hidden; }

  #ultra-portavista {
    height: 100vh;
    width: 100vw;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 2000px;
    position: relative;
    color: var(--cream);
    font-family: 'Oswald', sans-serif;
  }

  /* FX */
  .noise-bg { position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.2'/%3E%3C/svg%3E"); pointer-events: none; z-index: 100; }
  .red-flash-overlay { position: fixed; inset: 0; background: var(--blood); opacity: 0; pointer-events: none; z-index: 101; transition: opacity 0.1s; }
  .vignette { position: fixed; inset: 0; background: radial-gradient(circle, transparent 30%, #000 110%); z-index: 10; }

  /* HUD */
  .hud { position: fixed; inset: 40px; pointer-events: none; z-index: 1000; display: flex; flex-direction: column; justify-content: space-between; }
  .hud-top { display: flex; align-items: center; gap: 20px; font-size: 0.6rem; letter-spacing: 5px; opacity: 0.3; }
  .hud-line { flex-grow: 1; height: 1px; background: rgba(255,255,255,0.1); }
  .hud-mode { font-size: 0.5rem; opacity: 0.4; }
  
  .hud-credits { position: absolute; top: 50%; right: 0; transform: rotate(90deg) translateX(50%); transform-origin: right center; display: flex; gap: 15px; pointer-events: auto; }
  .hud-label { font-size: 0.5rem; opacity: 0.3; letter-spacing: 3px; }
  .hud-dev { color: var(--cream); text-decoration: none; font-size: 0.6rem; font-weight: 700; opacity: 0.5; transition: opacity 0.3s; letter-spacing: 2px; }
  .hud-dev:hover { opacity: 1; color: var(--blood); }

  .hud-bottom { display: flex; justify-content: space-between; align-items: flex-end; pointer-events: auto; }
  .status-box { display: flex; align-items: center; gap: 10px; font-size: 0.6rem; letter-spacing: 4px; color: var(--blood); }
  .pulse { width: 6px; height: 6px; background: var(--blood); border-radius: 50%; animation: pulse-blink 1s infinite; }
  @keyframes pulse-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
  .legal { font-size: 0.55rem; opacity: 0.15; letter-spacing: 3px; }

  /* ── THUMB NAV (NUEVO) ── */
  .thumb-nav { display: flex; gap: 15px; align-items: center; }
  .thumb-btn { background: none; border: 1px solid rgba(255,255,255,0.1); cursor: pointer; padding: 4px; transition: all 0.3s; position: relative; }
  .thumb-inner { width: 45px; height: 60px; overflow: hidden; position: relative; }
  .thumb-img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); opacity: 0.4; transition: all 0.3s; }
  .btn-overlay { position: absolute; inset: 0; background: var(--blood); opacity: 0; mix-blend-mode: color; transition: opacity 0.3s; }
  .btn-idx { position: absolute; top: -15px; left: 0; font-size: 0.5rem; color: var(--cream); opacity: 0.3; }
  
  .thumb-btn:hover .thumb-img, .thumb-btn.active .thumb-img { filter: grayscale(0); opacity: 1; }
  .thumb-btn.active { border-color: var(--blood); transform: translateY(-5px); }
  .thumb-btn.active .btn-overlay { opacity: 0.3; }

  /* ══════════════════════════════════════════
     STACK LOGIC (MULTIPLE DEPTH)
  ══════════════════════════════════════════ */
  .master-stack-container { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; z-index: 5; }
  .stack-wrapper { position: relative; width: clamp(300px, 40vw, 750px); height: clamp(400px, 60vh, 900px); transform-style: preserve-3d; }
  
  .stack-item { position: absolute; inset: 0; transition: all 0.8s cubic-bezier(0.19, 1, 0.22, 1); opacity: 0; transform: translateZ(-800px) scale(0.4); visibility: hidden; pointer-events: none; }
  
  /* Active item */
  .stack-item.active { opacity: 1; transform: translateZ(0) scale(1); visibility: visible; z-index: 50; pointer-events: auto; }
  
  /* Peeking behind */
  .stack-item.next { opacity: 0.4; transform: translateZ(-400px) translateX(10%) rotateY(-5deg); visibility: visible; z-index: 40; }
  .stack-item.next-2 { opacity: 0.15; transform: translateZ(-800px) translateX(20%) rotateY(-10deg); visibility: visible; z-index: 30; }
  
  .stack-item.exit { opacity: 0; transform: translateZ(1000px) scale(3); visibility: visible; z-index: 60; }

  .item-frame { width: 100%; height: 100%; background: #000; border: 1px solid rgba(255,255,255,0.1); position: relative; overflow: hidden; box-shadow: 0 50px 100px rgba(0,0,0,0.9); transition: border-color 0.3s; }
  .stack-img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.1); transition: filter 0.4s; }
  .stack-item.active .item-frame:hover .stack-img { filter: grayscale(0) contrast(1); }
  .stack-item.active .item-frame:hover { border-color: var(--blood); }

  .peek-label { position: absolute; top: 20px; right: 20px; font-size: 0.6rem; letter-spacing: 3px; color: var(--cream); opacity: 0.2; writing-mode: vertical-rl; transform: rotate(180deg); }

  .slam-data { position: absolute; bottom: 12vh; width: 100%; text-align: center; z-index: 100; pointer-events: none; }
  #active-label { font-size: clamp(2rem, 5vw, 4rem); font-weight: 900; letter-spacing: -2px; line-height: 1; margin-bottom: 0.5rem; text-shadow: 0 0 30px rgba(0,0,0,0.8); }
  #active-details { font-size: 0.7rem; letter-spacing: 5px; opacity: 0.4; }

  /* CINEMA MODE */
  .cinema-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.98); z-index: 9999; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.4s; backdrop-filter: blur(15px); }
  .cinema-overlay.active { opacity: 1; pointer-events: all; }
  .strobe-layer { position: absolute; inset: 0; background: radial-gradient(circle, rgba(230,0,0,0.15) 0%, transparent 70%); animation: strobe-hit 0.1s infinite alternate; opacity: 0; }
  .cinema-overlay.active .strobe-layer { opacity: 0.5; }
  @keyframes strobe-hit { 0% { opacity: 0.05; } 100% { opacity: 0.25; } }
  .cinema-content { width: 90%; max-width: 1400px; display: flex; flex-direction: column; align-items: center; gap: 3vh; }
  .cinema-img-box { width: 70%; max-height: 75vh; border: 1px solid rgba(255,255,255,0.05); position: relative; box-shadow: 0 0 120px rgba(0,0,0,1); }
  .cinema-img-box img { width: 100%; height: auto; display: block; filter: contrast(1.15) brightness(1.1); }
  #close-cinema { position: absolute; top: 40px; right: 40px; background: none; border: 1px solid rgba(255,255,255,0.2); color: #fff; padding: 10px 20px; font-size: 0.6rem; letter-spacing: 4px; cursor: pointer; transition: all 0.3s; }
  #close-cinema:hover { background: var(--blood); border-color: var(--blood); }
  #cinema-label { font-size: clamp(1.5rem, 5vw, 3rem); font-weight: 900; color: var(--blood); }
</style>

<script>
  function initUltraPortavista() {
    const stackItems = document.querySelectorAll('.stack-item');
    const thumbBtns = document.querySelectorAll('.thumb-btn');
    const labelDisplay = document.getElementById('active-label');
    const detailsDisplay = document.getElementById('active-details');
    const flashLayer = document.getElementById('flash');
    
    let currentIndex = 0;
    const total = stackItems.length;
    let autoPlay = true;

    function applySlamEffect() {
        if(flashLayer) {
            flashLayer.style.opacity = '0.25';
            setTimeout(() => { flashLayer.style.opacity = '0'; }, 100);
        }
    }

    function updateStack(forceIndex = -1) {
      if (forceIndex !== -1) currentIndex = forceIndex;

      stackItems.forEach((item, index) => {
        item.classList.remove('active', 'next', 'next-2', 'exit');
        
        if (index === currentIndex) {
          item.classList.add('active');
          const frame = item.querySelector('.item-frame');
          if(labelDisplay) labelDisplay.innerText = frame?.getAttribute('data-label') || '';
          if(detailsDisplay) detailsDisplay.innerText = frame?.getAttribute('data-details') || '';
        } 
        else if (index === (currentIndex + 1) % total) {
          item.classList.add('next');
        }
        else if (index === (currentIndex + 2) % total) {
            item.classList.add('next-2');
        }
        else if (index === (currentIndex - 1 + total) % total) {
          item.classList.add('exit');
        }
      });

      // Update thumbs
      thumbBtns.forEach((btn, i) => {
          btn.classList.toggle('active', i === currentIndex);
      });

      applySlamEffect();
      
      if (forceIndex === -1) {
          currentIndex = (currentIndex + 1) % total;
      }
    }

    let intervalId = setInterval(() => { if(autoPlay) updateStack(); }, 3500);
    updateStack(0);

    // ── INTERACCIÓN THUMBS ──
    thumbBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const index = parseInt(btn.getAttribute('data-index') || '0');
            updateStack(index);
            autoPlay = false; // Pausar un momento para que el usuario vea su elección
            setTimeout(() => autoPlay = true, 5000);
        });
    });

    const cinemaOverlay = document.getElementById('cinema-mode');
    const cinemaImg = document.getElementById('cinema-img') as HTMLImageElement;
    const cinemaLabel = document.getElementById('cinema-label');
    const cinemaDetails = document.getElementById('cinema-details');
    const closeCinema = document.getElementById('close-cinema');

    stackItems.forEach(item => {
        item.addEventListener('click', () => {
            autoPlay = false;
            const frame = item.querySelector('.item-frame');
            const img = item.querySelector('.stack-img') as HTMLImageElement;
            if(cinemaImg) cinemaImg.src = img.src;
            if(cinemaLabel) cinemaLabel.innerText = frame?.getAttribute('data-label') || '';
            if(cinemaDetails) cinemaDetails.innerText = frame?.getAttribute('data-details') || '';
            cinemaOverlay?.classList.add('active');
        });
    });

    closeCinema?.addEventListener('click', () => {
        cinemaOverlay?.classList.remove('active');
        autoPlay = true;
    });
  }
  document.addEventListener('DOMContentLoaded', initUltraPortavista);
</script>
