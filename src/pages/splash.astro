---
import logo from '../assets/logo.png';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fugitivos — Inicializando</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Oswald:wght@200..700&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream: #fff5e6;
      --red: #ff3e3e;
      --dark: #000;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--dark);
      color: var(--cream);
      font-family: 'Oswald', sans-serif;
      overflow: hidden;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ─── INITIAL CINEMATIC REVEAL ─── */
    .reveal-line {
      position: fixed;
      top: 50%; left: 0; width: 100%; height: 1px;
      background: var(--red);
      box-shadow: 0 0 20px var(--red);
      z-index: 100;
      animation: revealOpen 1.2s cubic-bezier(0.77, 0, 0.18, 1) forwards;
    }
    @keyframes revealOpen {
      0% { transform: scaleX(0); height: 1px; }
      40% { transform: scaleX(1); height: 1px; }
      100% { transform: scaleX(1); height: 100vh; opacity: 0; top: 0; }
    }

    /* ─── BACKGROUND FX ─── */
    .bg-fx {
      position: fixed;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }
    .noise {
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.1'/%3E%3C/svg%3E");
      opacity: 0.2;
    }
    .red-pulse {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 50%, rgba(255, 62, 62, 0.05) 0%, transparent 70%);
      animation: pulse 4s infinite alternate ease-in-out;
    }
    .watercolor-blur {
      position: absolute;
      width: 80vw;
      height: 80vh;
      background: var(--red);
      filter: blur(120px);
      border-radius: 50%;
      opacity: 0.07;
      top: 10%; left: 10%;
      animation: drift 15s infinite alternate ease-in-out;
      pointer-events: none;
    }
    @keyframes drift {
      0% { transform: translate(-10%, -10%) scale(1); }
      100% { transform: translate(10%, 10%) scale(1.1); }
    }
    @keyframes pulse {
      from { opacity: 0.3; transform: scale(1); }
      to { opacity: 0.7; transform: scale(1.1); }
    }

    /* ─── CONTENT ─── */
    .content {
      position: relative;
      z-index: 10;
      text-align: center;
      opacity: 0;
      animation: contentIn 0.8s 1.3s forwards;
    }
    @keyframes contentIn {
      from { opacity: 0; filter: blur(10px); transform: scale(0.9); }
      to { opacity: 1; filter: blur(0); transform: scale(1); }
    }

    .logo-container {
      margin-bottom: 3rem;
      position: relative;
    }
    .logo-img {
      height: clamp(140px, 28vh, 320px);
      width: auto;
      filter: grayscale(1) brightness(1.8) drop-shadow(0 0 30px rgba(255, 62, 62, 0.2));
      animation: logoFlicker 0.1s infinite alternate;
    }
    @keyframes logoFlicker {
      0% { opacity: 0.95; filter: grayscale(1) brightness(1.7); }
      100% { opacity: 1; filter: grayscale(1) brightness(1.9); }
    }

    /* ─── DATA UI ─── */
    .data-ui {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 4px;
      color: var(--red);
      margin-top: 1rem;
    }
    .loader-wrap {
      width: 240px;
      margin: 2rem auto 0;
    }
    .bar-track {
      width: 100%; height: 2px;
      background: rgba(255, 255, 255, 0.05);
      position: relative;
      overflow: hidden;
    }
    .bar-fill {
      position: absolute;
      left: 0; top: 0; height: 100%;
      width: 0%;
      background: var(--red);
      box-shadow: 0 0 10px var(--red);
      transition: width 0.1s;
    }

    /* ─── BUBBLE EXIT TRANSITION ─── */
    #exit-overlay {
      position: fixed;
      inset: 0;
      background: var(--cream);
      z-index: 1000;
      clip-path: circle(0% at 50% 50%);
      transition: clip-path 0.8s cubic-bezier(0.85, 0, 0.15, 1);
    }
    #exit-overlay.fire {
      clip-path: circle(150% at 50% 50%);
    }

    /* Corner Labels */
    .corner {
      position: fixed;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      opacity: 0.3;
      z-index: 20;
    }
    .tl { top: 2rem; left: 2rem; }
    .tr { top: 2rem; right: 2rem; }
  </style>
</head>
<body>
  <div class="reveal-line"></div>
  <div class="bg-fx">
    <div class="red-pulse"></div>
    <div class="watercolor-blur"></div>
    <div class="noise"></div>
  </div>

  <div class="corner tl">ID: FGT_INIT // STATUS: ACTIVE</div>
  <div class="corner tr" id="timer">00:00:00:00</div>

  <main class="content">
    <div class="logo-container">
      <img src={logo.src} alt="Fugitivos" class="logo-img" />
    </div>
    
    <div class="data-ui">
      <div id="status">INIT_SEQUENCE</div>
      <div class="loader-wrap">
        <div class="bar-track">
          <div class="bar-fill" id="bar"></div>
        </div>
      </div>
    </div>
  </main>

  <div id="exit-overlay"></div>

  <script>
    const bar = document.getElementById('bar');
    const status = document.getElementById('status');
    const timer = document.getElementById('timer');
    const labels = ['INIT_CORE', 'SYNC_WAVES', 'LOADING_MEDIA', 'DONE'];
    let pct = 0;

    // Timer
    setInterval(() => {
      const n = new Date();
      if (timer) {
        timer.innerText = n.toTimeString().split(' ')[0] + ':' + String(n.getMilliseconds()).padStart(3,'0').slice(0,2);
      }
    }, 50);

    // Progress - Starts after reveal line completes
    setTimeout(() => {
      const interval = setInterval(() => {
        pct += Math.random() * 2;
        if (pct >= 100) {
          pct = 100;
          clearInterval(interval);
          setTimeout(finish, 400);
        }
        if (bar) bar.style.width = pct + '%';
        if (status) status.innerText = labels[Math.floor((pct/100) * (labels.length - 1))];
      }, 35);
    }, 1200);

    function finish() {
      sessionStorage.setItem('splashTs', Date.now().toString());
      const overlay = document.getElementById('exit-overlay');
      if (overlay) overlay.classList.add('fire');
      setTimeout(() => {
        window.location.href = '/info';
      }, 750);
    }
  </script>
</body>
</html>
