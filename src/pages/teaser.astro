---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
import coverHastaMisMiedos from "../assets/imagen portada (1).jpeg";
import coverDelMismoLado from "../assets/Captura desde 2026-04-22 19-06-28.png";
import Header from "../components/Header.astro";

// Mock data for teasers - we will scale this later
const teasers = [
  {
    id: "hasta-mis-miedos",
    title: "HASTA MIS MIEDOS",
    date: "12 MAY 2026",
    status: "DISPONIBLE",
    image: coverHastaMisMiedos,
    url: "/teasers/hasta-mis-miedos",
    bpm: "142",
    length: "0:45"
  },
  {
    id: "del-mismo-lado",
    title: "DEL MISMO LADO",
    date: "12 ABR 2026",
    status: "DISPONIBLE",
    image: coverDelMismoLado,
    url: "/teasers/del-mismo-lado",
    bpm: "128",
    length: "3:42"
  },
  {
    id: "proximamente-1",
    title: "???",
    date: "JUNIO 2026",
    status: "BLOQUEADO",
    image: null,
    url: "#",
    bpm: "???",
    length: "???"
  }
];
---

<Layout>
  <main class="teaser-hub">
    <!-- ── BACKGROUND FX ── -->
    <div class="hub-bg">
      <div class="noise-overlay"></div>
      <div class="scanlines"></div>
      <div class="vignette"></div>
      <div class="ambient-light"></div>
    </div>

    <Header />

    <!-- ── HUB INTERFACE ── -->
    <div class="hub-ui">
      <!-- Top Bar Spacer -->
      <div class="header-spacer" style="height: 100px;"></div>


      <!-- Main Selection Grid -->
      <section class="teaser-grid">
        <div class="grid-label">SELECCIONAR ARCHIVO DE AUDIO</div>
        
        <div class="cards-container">
          {teasers.map((t, index) => (
            <a href={t.url} class={`teaser-card ${t.status === 'BLOQUEADO' ? 'locked' : ''}`} data-id={t.id}>
              <div class="card-inner">
                <!-- Glitch Background -->
                <div class="card-bg"></div>
                
                <!-- Media Section -->
                <div class="card-media">
                  {t.image ? (
                    <Image src={t.image} alt={t.title} class="card-img" />
                  ) : (
                    <div class="locked-placeholder">
                      <span class="lock-icon">🔒</span>
                      <div class="decryption-progress">
                        <div class="progress-bar"></div>
                        <span class="progress-pct">92% DESCIFRANDO...</span>
                      </div>
                      <div class="static-noise"></div>
                    </div>
                  )}
                  <div class="media-overlay"></div>
                  <!-- Holographic Shine -->
                  <div class="card-shine"></div>
                </div>

                <!-- Info Section -->
                <div class="card-content">
                  <div class="card-meta">
                    <span class="meta-item">NO. {String(index + 1).padStart(2, '0')}</span>
                    <span class="meta-item">{t.status}</span>
                  </div>
                  <h2 class="card-title">{t.title}</h2>
                  <div class="card-footer">
                    <div class="stats">
                      <span>BPM: {t.bpm}</span>
                      <span>DUR: {t.length}</span>
                    </div>
                    <div class="card-date">{t.date}</div>
                  </div>
                </div>

                <!-- Corner Decorations -->
                <div class="corner tl"></div>
                <div class="corner tr"></div>
                <div class="corner bl"></div>
                <div class="corner br"></div>
              </div>
              
              <!-- Hover FX: Leaking code -->
              <div class="card-hover-fx">
                <span>LOADING_DATA...</span>
                <span>DECRYPTING_AUDIO...</span>
                <span>{t.id.toUpperCase()}</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Bottom Status Bar -->
      <footer class="hub-footer">
        <div class="footer-left">
          <div class="ticker-wrap">
            <div class="ticker">
              ++ FUGITIVOS_VAULT ++ SELECCIONA UN TEASER PARA REPRODUCIR ++ ADVERTENCIA: CONTENIDO NO FILTRADO ++
            </div>
          </div>
        </div>
        <div class="footer-right">
          <span id="coord-display">X: 000 Y: 000</span>
        </div>
      </footer>
    </div>

    <!-- ── AUDIO & CURSOR ── -->
    <div id="custom-cursor"></div>
  </main>
</Layout>

<style>
  :root {
    --cream: #fff5e6;
    --red: #ff3e3e;
    --dark: #0a0a0a;
    --gray: #1a1a1a;
  }

  .teaser-hub {
    position: fixed;
    inset: 0;
    background: var(--dark);
    color: var(--cream);
    font-family: 'Oswald', sans-serif;
    overflow: hidden;
    cursor: none;
  }

  /* ── INITIAL DECRYPTION ANIMATION ── */
  body.is-decrypting .hub-ui {
    animation: decryption-flicker 1.5s steps(4);
  }
  @keyframes decryption-flicker {
    0% { opacity: 0; filter: brightness(5) blur(10px); }
    20% { opacity: 1; filter: brightness(1) blur(0); }
    40% { opacity: 0.5; filter: brightness(3) blur(5px); }
    60% { opacity: 1; filter: brightness(1) blur(0); }
    100% { opacity: 1; }
  }

  /* ── BACKGROUND ── */
  .hub-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .noise-overlay {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.15'/%3E%3C/svg%3E");
    opacity: 0.1;
    pointer-events: none;
  }
  .scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.3) 2px, rgba(0,0,0,0.3) 4px);
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .scanlines.active {
    animation: scan-flicker 0.1s infinite;
    opacity: 0.8;
  }
  @keyframes scan-flicker {
    0% { transform: translateY(0); }
    50% { transform: translateY(2px); }
    100% { transform: translateY(0); }
  }
  .ambient-light {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255, 62, 62, 0.05) 0%, transparent 70%);
  }

  /* ── UI STRUCTURE ── */
  .hub-ui {
    position: relative;
    z-index: 10;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  /* Header */
  .hub-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1px solid rgba(255,245,230,0.1);
    padding-bottom: 1rem;
  }
  .hub-logo {
    height: 40px;
    filter: grayscale(1) brightness(1.5);
  }
  .system-status {
    font-size: 0.7rem;
    letter-spacing: 2px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    opacity: 0.6;
  }
  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--red);
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }
  @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }

  .terminal-text {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--red);
    text-align: right;
  }
  .back-link {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 3px;
    color: var(--cream);
    text-decoration: none;
    opacity: 0.4;
    transition: opacity 0.3s;
  }
  .back-link:hover { opacity: 1; }

  /* Grid */
  .teaser-grid {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
  }
  .grid-label {
    font-size: 0.6rem;
    letter-spacing: 8px;
    opacity: 0.3;
    margin-bottom: 3rem;
    text-transform: uppercase;
  }

  .cards-container {
    display: flex;
    gap: 3rem;
    perspective: 2000px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── CARDS ── */
  .teaser-card {
    position: relative;
    width: 320px;
    height: 450px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    transform-style: preserve-3d;
  }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--gray);
    border: 1px solid rgba(255,245,230,0.1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color 0.4s;
  }

  .teaser-card:hover {
    transform: translateY(-20px) rotateX(5deg) rotateY(-5deg);
  }
  .teaser-card:hover .card-inner {
    border-color: var(--red);
    box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 20px rgba(255, 62, 62, 0.1);
  }

  /* Media Area */
  .card-media {
    height: 60%;
    position: relative;
    background: #000;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.2);
    transition: transform 0.8s, filter 0.8s;
  }

  /* Holographic Shine */
  .card-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 255, 255, 0.05) 30%,
      rgba(255, 255, 255, 0.2) 40%,
      rgba(255, 255, 255, 0.05) 50%,
      transparent 70%
    );
    z-index: 5;
    transform: translateX(-100%);
    transition: opacity 0.5s ease;
    mix-blend-mode: overlay;
    pointer-events: none;
    opacity: 0;
  }

  .teaser-card:hover .card-img {
    transform: scale(1.1);
    filter: grayscale(0) contrast(1);
  }
  .media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--gray), transparent);
  }

  /* Locked State */
  .locked {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .locked-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #050505;
    gap: 1rem;
  }
  .lock-icon { font-size: 2rem; opacity: 0.2; }

  .decryption-progress {
    width: 60%;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .progress-bar {
    width: 100%;
    height: 2px;
    background: rgba(255, 62, 62, 0.1);
    position: relative;
    overflow: hidden;
  }
  .progress-bar::after {
    content: '';
    position: absolute;
    left: 0; top: 0; height: 100%;
    width: 92%;
    background: var(--red);
    box-shadow: 0 0 10px var(--red);
    animation: load-pulse 2s infinite alternate;
  }
  @keyframes load-pulse {
    from { opacity: 0.5; }
    to { opacity: 1; }
  }
  .progress-pct {
    font-size: 0.5rem;
    letter-spacing: 2px;
    color: var(--red);
    text-align: center;
    font-family: monospace;
  }
  .static-noise {
    position: absolute;
    inset: 0;
    background: url("https://media.giphy.com/media/oEI9uWUqWMrBK/giphy.gif");
    background-size: cover;
    opacity: 0.05;
    mix-blend-mode: screen;
  }

  /* Content Area */
  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.6rem;
    letter-spacing: 2px;
    opacity: 0.4;
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1.8rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: auto;
    letter-spacing: -1px;
    text-transform: uppercase;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 1rem;
  }
  .stats {
    display: flex;
    flex-direction: column;
    font-size: 0.6rem;
    opacity: 0.4;
    gap: 2px;
  }
  .card-date {
    font-size: 0.7rem;
    letter-spacing: 2px;
    font-weight: 700;
  }

  /* Decorations */
  .corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid var(--red);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .tl { top: -5px; left: -5px; border-right: 0; border-bottom: 0; }
  .tr { top: -5px; right: -5px; border-left: 0; border-bottom: 0; }
  .bl { bottom: -5px; left: -5px; border-right: 0; border-top: 0; }
  .br { bottom: -5px; right: -5px; border-left: 0; border-top: 0; }

  .teaser-card:hover .corner { opacity: 1; }

  /* Hover FX Text */
  .card-hover-fx {
    position: absolute;
    top: 50%;
    left: -20px;
    transform: translateY(-50%) rotate(-90deg);
    font-family: monospace;
    font-size: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 10px;
    opacity: 0;
    transition: opacity 0.3s, left 0.3s;
    pointer-events: none;
    color: var(--red);
  }
  .teaser-card:hover .card-hover-fx {
    opacity: 1;
    left: -60px;
  }

  /* ── FOOTER ── */
  .hub-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255,245,230,0.1);
    padding-top: 1rem;
  }
  .ticker-wrap {
    width: 400px;
    overflow: hidden;
    font-size: 0.6rem;
    letter-spacing: 2px;
    opacity: 0.3;
  }
  .ticker {
    display: inline-block;
    white-space: nowrap;
    animation: ticker 15s linear infinite;
  }
  @keyframes ticker { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }

  #coord-display {
    font-family: monospace;
    font-size: 0.7rem;
    opacity: 0.3;
  }

  /* ── CURSOR ── */
  #custom-cursor {
    position: fixed;
    width: 30px;
    height: 30px;
    border: 1px solid var(--cream);
    border-radius: 50%;
    pointer-events: none;
    z-index: 10000;
    transform: translate(-50%, -50%);
    mix-blend-mode: difference;
    transition: transform 0.1s;
  }

  @media (max-width: 768px) {
    .hub-ui { padding: 1.5rem 1rem; }
    .header-spacer { height: 80px !important; }
    
    .teaser-grid {
      justify-content: flex-start;
      padding-top: 1rem;
    }
    
    .grid-label {
      margin-bottom: 2rem;
      text-align: center;
    }

    .cards-container { 
      gap: 2rem;
      flex-direction: column;
      align-items: center;
      padding-bottom: 5rem; /* Space for footer */
      overflow-y: auto;
      max-height: calc(100vh - 200px);
      scrollbar-width: none;
    }
    .cards-container::-webkit-scrollbar { display: none; }

    .teaser-card { 
      width: 100%; 
      max-width: 300px;
      height: 420px; 
    }
    
    .card-title { font-size: 1.5rem; }
    
    .hub-footer {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    .footer-right { display: none; } /* Hide coords on mobile */
    .ticker-wrap { width: 100%; }

    /* Disable custom cursor on mobile */
    #custom-cursor { display: none; }
    .teaser-hub { cursor: auto; }
  }

  @media (max-width: 480px) {
    .teaser-card {
      height: 380px;
    }
  }
</style>

<script>
  // CURSOR
  const cursor = document.getElementById('custom-cursor');
  const coords = document.getElementById('coord-display');

  window.addEventListener('mousemove', (event) => {
    const e = event as MouseEvent;
    if (cursor) {
      cursor.style.left = e.clientX + 'px';
      cursor.style.top = e.clientY + 'px';
    }
    if (coords) {
      coords.innerText = `X: ${String(e.clientX).padStart(3, '0')} Y: ${String(e.clientY).padStart(3, '0')}`;
    }
  });

  // CARD TILT (Advanced)
  const cards = document.querySelectorAll('.teaser-card');
  const scanlines = document.querySelector('.scanlines');

  cards.forEach(card => {
    const shine = card.querySelector('.card-shine') as HTMLElement;

    card.addEventListener('mousemove', (event) => {
      const e = event as MouseEvent;
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 10;
      const rotateY = (centerX - x) / 10;
      
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-20px) scale(1.02)`;
      
      // Update shine position
      if (shine) {
        const shineX = (x / rect.width) * 200 - 100;
        shine.style.transform = `translateX(${shineX}%) skewX(-20deg)`;
        shine.style.opacity = '1';
      }

      // Activate scanlines
      if (scanlines) scanlines.classList.add('active');
    });

    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) translateY(0) scale(1)`;
      if (shine) {
        shine.style.opacity = '0';
      }
      if (scanlines) scanlines.classList.remove('active');
    });
  });

  // INITIAL DECRYPTION ANIMATION
  window.addEventListener('load', () => {
    document.body.classList.add('is-decrypting');
    setTimeout(() => {
      document.body.classList.remove('is-decrypting');
    }, 1500);
  });
</script>
