---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import coverImage from "../../assets/Captura desde 2026-04-22 19-06-28.png";
import Header from "../../components/Header.astro";

---

<Layout title="Fugitivos — Del Mismo Lado (Teaser)">
	<main class="teaser-peaceful del-mismo-lado">
		<!-- ── SVG FILTERS (LIQUID EFFECT) ── -->
		<svg style="position: absolute; width: 0; height: 0;">
			<filter id="liquid-filter">
				<feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="3" result="noise">
					<animate attributeName="baseFrequency" values="0.02;0.03;0.02" dur="10s" repeatCount="indefinite" />
				</feTurbulence>
				<feDisplacementMap in="SourceGraphic" in2="noise" scale="10" />
			</filter>
		</svg>

		<!-- ── BACKGROUND: DYNAMIC WATERCOLOR VAULT ── -->
		<div class="canvas-bg">
			<!-- Morphing Blobs Layer 1 -->
			<div class="blob-container">
				<div class="morph-blob teal-blob"></div>
				<div class="morph-blob orange-blob"></div>
				<div class="morph-blob cream-blob"></div>
			</div>
			
			<!-- Parallax Depth Layers -->
			<div class="parallax-layer layer-1" id="p-layer-1"></div>
			<div class="parallax-layer layer-2" id="p-layer-2"></div>

			<!-- Textures & Overlays -->
			<div class="particles-container" id="particles"></div>
			<div class="vignette-overlay"></div>
			<div class="paper-texture"></div>
			<div class="artistic-grain"></div>
		</div>

		<!-- ── UI: BACK BUTTON ── -->
		<a href="/teaser" class="back-link-organic">
			<span class="line"></span>
			<span class="text">BÓVEDA</span>
		</a>

		<div class="content-wrapper">
			<section class="teaser-hero">
				<!-- Cover with Soft Shadow & Float -->
				<div class="cover-wrapper" id="floating-cover">
					<div class="cover-glow"></div>
					<Image src={coverImage} alt="Del Mismo Lado" class="main-cover" />
				</div>

				<div class="info-block">
					<div class="title-wrap">
						<h1 class="song-title-peace">DEL MISMO LADO</h1>
						<div class="separator-wave">
							<svg viewBox="0 0 100 20" preserveAspectRatio="none">
								<path d="M0,10 Q25,0 50,10 T100,10" fill="none" stroke="currentColor" stroke-width="1"></path>
							</svg>
						</div>
					</div>
					<p class="song-desc">Siente la calma del reflejo. Una conexión que trasciende el espacio.</p>
					
					<div class="cta-group">
						<a href="https://open.spotify.com/intl-es/track/2uzHx2LeOQq9e0MeW0D9Ne" target="_blank" class="btn-organic">
							<span>ESCUCHAR</span>
						</a>
						<a href="https://youtu.be/uNsP8LHagWQ" target="_blank" class="btn-organic outline">
							<span>VIDEO</span>
						</a>
					</div>
				</div>
			</section>
		</div>

		<!-- ── FLOATING SPOTIFY (MINIMAL) ── -->
		<div class="spotify-minimal" id="spotify-card">
			<iframe
				src="https://open.spotify.com/embed/track/2uzHx2LeOQq9e0MeW0D9Ne?utm_source=generator&theme=0"
				width="100%"
				height="80"
				frameborder="0"
				allowfullscreen=""
				allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
				loading="lazy"
			></iframe>
		</div>

		<!-- ── HIDDEN AUDIO ── -->
		<div style="display:none">
			<div id="yt-player"></div>
		</div>

		<script is:inline>
			var ytScript = document.createElement("script");
			ytScript.src = "https://www.youtube.com/iframe_api";
			var firstScript = document.getElementsByTagName("script")[0];
			firstScript.parentNode.insertBefore(ytScript, firstScript);

			var ytPlayer;
			function onYouTubeIframeAPIReady() {
				ytPlayer = new YT.Player("yt-player", {
					height: "0",
					width: "0",
					videoId: "uNsP8LHagWQ",
					playerVars: {
						autoplay: 1,
						loop: 1,
						playlist: "uNsP8LHagWQ",
					},
					events: {
						onReady: function (event) {
							event.target.setVolume(15);
						},
					},
				});
			}
		</script>
	</main>
</Layout>

<style>
	:root {
		--paper: #f9f6f1;
		--teal: #4a7c8c;
		--orange: #d97d54;
		--dark-text: #2a3d45;
	}

	.teaser-peaceful {
		background-color: var(--paper);
		color: var(--dark-text);
		min-height: 100vh;
		position: relative;
		overflow: hidden;
		font-family: 'Oswald', sans-serif;
		display: flex;
		flex-direction: column;
	}

	/* ── DYNAMIC BACKGROUND ── */
	.canvas-bg {
		position: fixed;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: #fdfaf5;
	}

	.blob-container {
		position: absolute;
		inset: 0;
		filter: blur(80px) contrast(1.2);
		opacity: 0.4;
	}

	.morph-blob {
		position: absolute;
		border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
		animation: morphing 15s infinite alternate ease-in-out;
		opacity: 0.6;
	}

	.teal-blob {
		width: 80vw;
		height: 80vh;
		background: var(--teal);
		top: -20%;
		right: -10%;
	}

	.orange-blob {
		width: 70vw;
		height: 70vh;
		background: var(--orange);
		bottom: -15%;
		left: -10%;
		animation-duration: 20s;
		animation-delay: -5s;
	}

	.cream-blob {
		width: 100vw;
		height: 100vh;
		background: #f5e6d3;
		top: 10%;
		left: 10%;
		z-index: -1;
	}

	@keyframes morphing {
		0% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: rotate(0deg) scale(1); }
		33% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; transform: rotate(120deg) scale(1.1); }
		66% { border-radius: 100% 60% 60% 100% / 100% 100% 60% 60%; transform: rotate(240deg) scale(0.9); }
		100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: rotate(360deg) scale(1); }
	}

	.parallax-layer {
		position: absolute;
		inset: -10%;
		background-size: cover;
		pointer-events: none;
		opacity: 0.05;
		mix-blend-mode: multiply;
	}
	.layer-1 {
		background-image: url("https://www.transparenttextures.com/patterns/handmade-paper.png");
	}
	.layer-2 {
		background-image: url("https://www.transparenttextures.com/patterns/pinstriped-suit.png");
		opacity: 0.03;
	}

	.vignette-overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle, transparent 20%, rgba(42, 61, 69, 0.08) 100%);
	}

	.artistic-grain {
		position: absolute;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.15'/%3E%3C/svg%3E");
		opacity: 0.12;
		mix-blend-mode: overlay;
	}

	.particles-container {
		position: absolute;
		inset: 0;
		z-index: 2;
	}
	.particle {
		position: absolute;
		border-radius: 50%;
		opacity: 0.15;
		pointer-events: none;
	}
	.paper-texture {
		position: absolute;
		inset: 0;
		background-image: url("https://www.transparenttextures.com/patterns/paper-fibers.png");
		opacity: 0.4;
		mix-blend-mode: multiply;
	}
	.ink-bleed {
		position: absolute;
		border-radius: 50%;
		filter: blur(100px);
		opacity: 0.15;
		animation: float 20s infinite alternate ease-in-out;
	}
	.bleed-1 {
		width: 60vw;
		height: 60vw;
		background: var(--teal);
		top: -10%;
		right: -10%;
	}
	.bleed-2 {
		width: 50vw;
		height: 50vw;
		background: var(--orange);
		bottom: -10%;
		left: -10%;
		animation-delay: -5s;
	}
	@keyframes float {
		from { transform: translate(0, 0) scale(1); }
		to { transform: translate(5%, 5%) scale(1.1); }
	}

	/* ── UI ELEMENTS ── */
	.back-link-organic {
		position: fixed;
		top: 120px;
		left: 4vw;
		z-index: 100;
		display: flex;
		align-items: center;
		gap: 1rem;
		text-decoration: none;
		color: var(--teal);
		opacity: 0.6;
		transition: opacity 0.3s;
	}
	.back-link-organic:hover { opacity: 1; }
	.back-link-organic .line {
		width: 30px;
		height: 1px;
		background: currentColor;
	}
	.back-link-organic .text {
		font-size: 0.7rem;
		letter-spacing: 5px;
		font-weight: 700;
	}

	/* ── CONTENT ── */
	.content-wrapper {
		position: relative;
		z-index: 10;
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		margin-top: 60px;
	}

	.teaser-hero {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: center;
		max-width: 1100px;
		width: 100%;
	}

	.cover-wrapper {
		position: relative;
		width: 100%;
		aspect-ratio: 1;
		border-radius: 4px;
		box-shadow: 0 30px 60px rgba(0,0,0,0.1);
		transition: transform 0.1s ease-out;
	}
	.main-cover {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 4px;
		position: relative;
		z-index: 2;
		filter: url(#liquid-filter); /* LIQUID WAVE EFFECT */
	}
	.cover-glow {
		position: absolute;
		inset: -20px;
		background: radial-gradient(circle, var(--teal) 0%, transparent 70%);
		opacity: 0.1;
		filter: blur(20px);
	}

	.info-block {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.song-title-peace {
		font-size: clamp(3rem, 6vw, 6rem);
		font-weight: 900;
		line-height: 0.9;
		color: var(--teal);
		letter-spacing: -2px;
	}
	.separator-wave {
		width: 100px;
		height: 20px;
		color: var(--orange);
		margin-top: 1rem;
	}

	.song-desc {
		font-size: 1.1rem;
		line-height: 1.6;
		max-width: 40ch;
		opacity: 0.7;
		font-weight: 300;
	}

	.cta-group {
		display: flex;
		gap: 1.5rem;
		margin-top: 1rem;
	}

	.btn-organic {
		background: var(--teal);
		color: white;
		padding: 1.2rem 2.5rem;
		border-radius: 50px;
		text-decoration: none;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 3px;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		box-shadow: 0 10px 20px rgba(74, 124, 140, 0.2);
	}
	.btn-organic:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 30px rgba(74, 124, 140, 0.3);
		background: var(--dark-text);
	}
	.btn-organic.outline {
		background: transparent;
		color: var(--teal);
		border: 1px solid var(--teal);
		box-shadow: none;
	}
	.btn-organic.outline:hover {
		background: var(--teal);
		color: white;
	}

	/* ── SPOTIFY ── */
	.spotify-minimal {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		width: 300px;
		z-index: 100;
		opacity: 0.8;
		transition: opacity 0.3s, transform 0.3s;
	}
	.spotify-minimal:hover {
		opacity: 1;
		transform: translateY(-5px);
	}

	@media (max-width: 900px) {
		.teaser-hero {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 3rem;
		}
		.cover-wrapper {
			max-width: 400px;
			margin: 0 auto;
		}
		.info-block { align-items: center; }
		.cta-group { justify-content: center; }
		.back-link-organic { top: 100px; left: 50%; transform: translateX(-50%); }
	}

	@media (max-width: 600px) {
		.spotify-minimal {
			width: calc(100% - 4rem);
			left: 2rem;
		}
		.song-title-peace { font-size: 2.5rem; }
	}
</style>

<script>
	// PARALLAX FLOAT
	const cover = document.getElementById('floating-cover');
	const l1 = document.getElementById('p-layer-1');
	const l2 = document.getElementById('p-layer-2');

	window.addEventListener('mousemove', (e) => {
		const xVal = (e.clientX - window.innerWidth / 2);
		const yVal = (e.clientY - window.innerHeight / 2);

		if (cover) {
			cover.style.transform = `translate(${xVal / 40}px, ${yVal / 40}px) rotateX(${-yVal / 80}deg) rotateY(${xVal / 80}deg)`;
		}
		if (l1) l1.style.transform = `translate(${xVal / 60}px, ${yVal / 60}px)`;
		if (l2) l2.style.transform = `translate(${xVal / 30}px, ${yVal / 30}px)`;
	});

	// PARTICLES SYSTEM (Paint Droplets)
	const pContainer = document.getElementById('particles');
	if (pContainer) {
		for (let i = 0; i < 15; i++) {
			const p = document.createElement('div');
			p.className = 'particle';
			const size = Math.random() * 100 + 50;
			p.style.width = size + 'px';
			p.style.height = size + 'px';
			p.style.left = Math.random() * 100 + '%';
			p.style.top = Math.random() * 100 + '%';
			p.style.background = Math.random() > 0.5 ? 'var(--teal)' : 'var(--orange)';
			p.style.filter = 'blur(40px)';
			
			// Simple float animation
			const duration = Math.random() * 20 + 10;
			p.animate([
				{ transform: 'translate(0, 0) scale(1)' },
				{ transform: `translate(${Math.random() * 100 - 50}px, ${Math.random() * 100 - 50}px) scale(1.2)` }
			], {
				duration: duration * 1000,
				iterations: Infinity,
				direction: 'alternate',
				easing: 'ease-in-out'
			});
			
			pContainer.appendChild(p);
		}
	}
</script>
